# Django
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_NAME=The Wardrobe Door

# Database: use sqlite for local dev, or postgresql for production
DB_ENGINE=sqlite

# PostgreSQL (only when DB_ENGINE=postgresql)
DB_NAME=wardrobe_door
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# Mailtrap SMTP (get credentials from mailtrap.io → Email Testing → SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_HOST_USER=your_mailtrap_username
EMAIL_HOST_PASSWORD=your_mailtrap_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=The Wardrobe Door <noreply@wardrobe-door.com>

# django-allauth: optional | mandatory | none
ACCOUNT_EMAIL_VERIFICATION=none

# Production only (your live domain)
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
